<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Satva Botanique | Pure Vegetarian Fine Dining</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Poppins:wght@300;400&display=swap" rel="stylesheet">

<style>
:root{
    --green:#2f5d50;
    --gold:#c6a75e;
    --ivory:#f7f4ef;
    --brown:#3a2f25;
    --price:#2b1f16;
}
body{
    margin:0;
    font-family:'Poppins',sans-serif;
    background:var(--ivory);
    color:var(--brown);
}
.container{
    max-width:1100px;
    margin:auto;
    padding:25px;
}
header{
    text-align:center;
    padding:45px 20px;
    border-bottom:2px solid var(--gold);
}
header h1{
    font-family:'Playfair Display',serif;
    font-size:48px;
    color:var(--green);
}
header p{letter-spacing:3px;font-size:14px;}
.veg-badge{
    margin-top:15px;
    padding:6px 18px;
    border:1px solid var(--green);
    color:var(--green);
    display:inline-block;
    font-size:12px;
}
.section{margin:55px 0;}
.section h2{
    font-family:'Playfair Display',serif;
    font-size:32px;
    color:var(--green);
    border-bottom:1px solid var(--gold);
    padding-bottom:10px;
    margin-bottom:25px;
}
.menu-item{
    display:flex;
    justify-content:space-between;
    align-items:center;
    font-size:15.5px;
    font-weight:500;
}
.price{color:var(--price);font-weight:700;}
.add-btn{
    margin-left:10px;
    background:var(--green);
    color:#fff;
    border:none;
    padding:3px 8px;
    font-size:11px;
    cursor:pointer;
}
.desc{
    font-size:12.5px;
    color:#6b5f55;
    margin-bottom:20px;
}
.cart{
    border:1px solid var(--gold);
    padding:20px;
    background:#fff;
    margin-top:60px;
}
.cart h3{
    font-family:'Playfair Display',serif;
    color:var(--green);
}
.cart-item{
    display:flex;
    justify-content:space-between;
    font-size:13px;
}
.total{font-weight:700;margin-top:10px;}
.order-btn{
    margin-top:15px;
    background:var(--green);
    color:#fff;
    border:none;
    padding:8px 15px;
    cursor:pointer;
}
footer{
    text-align:center;
    padding:30px;
    border-top:1px solid var(--gold);
    font-size:12px;
}
</style>
</head>

<body>
