<script>
let cart=[], total=0;
function addToCart(n,p){cart.push({n,p});total+=p;render();}
function render(){
  let c=document.getElementById("cartItems");c.innerHTML="";
  cart.forEach(i=>c.innerHTML+=`<div class="cart-item"><span>${i.n}</span><span>₹${i.p}</span></div>`);
  document.getElementById("total").innerText=total;
}
function orderWhatsApp(){
  let m="Order from Satva Botanique:%0A";
  cart.forEach(i=>m+=`- ${i.n} ₹${i.p}%0A`);
  m+=`Total: ₹${total}`;
  window.open("https://wa.me/919999922222?text="+m);
}
function payUPI(){
  if(total==0){alert("Please add items first");return;}
  window.location.href=`upi://pay?pa=satvabotanique7@upi&pn=Satva%20Botanique&am=${total}&cu=INR`;
}
</script>

