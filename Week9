<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weather Info Panel</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .weather-card {
            backdrop-filter: blur(20px);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .weather-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }
        .nagpur-bg {
            background: linear-gradient(135deg, #f97316, #ef4444, #dc2626);
        }
        .bangalore-bg {
            background: linear-gradient(135deg, #22c55e, #14b8a6, #0ea5e9);
        }
        .delhi-bg {
            background: linear-gradient(135deg, #eab308, #f59e0b, #f97316);
        }
        .sun-icon {
            animation: pulse-glow 2s ease-in-out infinite;
        }
        .cloud-icon {
            animation: float 3s ease-in-out infinite;
        }
        .haze-icon {
            animation: drift 4s ease-in-out infinite;
        }
        @keyframes pulse-glow {
            0%, 100% { filter: drop-shadow(0 0 8px rgba(251, 191, 36, 0.6)); }
            50% { filter: drop-shadow(0 0 20px rgba(251, 191, 36, 0.9)); }
        }
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        @keyframes drift {
            0%, 100% { transform: translateX(0); opacity: 0.8; }
            50% { transform: translateX(6px); opacity: 1; }
        }
        .detail-item {
            transition: background 0.2s ease;
        }
        .detail-item:hover {
            background: rgba(255, 255, 255, 0.15);
        }
        .page-bg {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            min-height: 100vh;
        }
        .glow-ring {
            box-shadow: 0 0 40px rgba(255, 255, 255, 0.05);
        }
        .temp-display {
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
        }
        .sparkle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: white;
            border-radius: 50%;
            opacity: 0;
            animation: sparkle-anim 3s ease-in-out infinite;
        }
        @keyframes sparkle-anim {
            0%, 100% { opacity: 0; transform: scale(0); }
            50% { opacity: 0.7; transform: scale(1); }
        }
    </style>
</head>
<body class="page-bg">
    <!-- Header -->
    <div class="pt-10 pb-6 text-center">
        <div class="inline-flex items-center gap-3 mb-3">
            <svg class="w-10 h-10 text-blue-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/>
            </svg>
            <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight">Weather <span class="text-blue-400">Panel</span></h1>
        </div>
        <p class="text-slate-400 text-lg">Current weather conditions for Indian cities</p>
        <div class="mt-3 inline-flex items-center gap-2 bg-slate-800/60 px-4 py-2 rounded-full border border-slate-700">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <span class="text-slate-300 text-sm" id="lastUpdated">Last updated: --</span>
        </div>
    </div>
    <!-- Weather Cards -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8" id="cardsContainer">
            <!-- Cards will be injected by JS -->
        </div>
        <!-- Comparison Table -->
        <div class="mt-14 bg-slate-800/50 rounded-2xl border border-slate-700 overflow-hidden backdrop-blur-sm">
            <div class="px-6 py-5 border-b border-slate-700 flex items-center gap-3">
                <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"/>
                </svg>
                <h2 class="text-xl font-semibold text-white">Quick Comparison</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-slate-400 text-sm uppercase tracking-wider">
                            <th class="px-6 py-4 font-medium">Parameter</th>
                            <th class="px-6 py-4 font-medium text-center">🍊 Nagpur</th>
                            <th class="px-6 py-4 font-medium text-center">🌿 Bangalore</th>
                            <th class="px-6 py-4 font-medium text-center">🏛️ Delhi</th>
                        </tr>
                    </thead>
                    <tbody id="comparisonBody">
                        <!-- Rows injected by JS -->
                    </tbody>
                </table>
            </div>
        </div>
        <!-- Fun Facts -->
        <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-slate-800/40 rounded-xl border border-slate-700 p-5 flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-orange-500/20 flex items-center justify-center shrink-0">
                    <span class="text-xl">🌡️</span>
                </div>
                <div>
                    <h3 class="text-white font-medium mb-1">Hottest City</h3>
                    <p class="text-slate-400 text-sm" id="hottestCity">--</p>
                </div>
            </div>
            <div class="bg-slate-800/40 rounded-xl border border-slate-700 p-5 flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-blue-500/20 flex items-center justify-center shrink-0">
                    <span class="text-xl">💧</span>
                </div>
                <div>
                    <h3 class="text-white font-medium mb-1">Most Humid</h3>
                    <p class="text-slate-400 text-sm" id="humidCity">--</p>
                </div>
            </div>
            <div class="bg-slate-800/40 rounded-xl border border-slate-700 p-5 flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center shrink-0">
                    <span class="text-xl">💨</span>
                </div>
                <div>
                    <h3 class="text-white font-medium mb-1">Windiest City</h3>
                    <p class="text-slate-400 text-sm" id="windiestCity">--</p>
                </div>
            </div>
        </div>
    </div>
    <script>
        // Static Weather Data
        const weatherData = [
            {
                city: "Nagpur",
                state: "Maharashtra",
                temp: 38,
                feelsLike: 41,
                high: 42,
                low: 28,
                condition: "Sunny",
                description: "Clear skies with intense heat",
                humidity: 35,
                wind: 12,
                windDir: "SW",
                visibility: 8,
                uvIndex: 9,
                pressure: 1008,
                dewPoint: 21,
                cloudCover: 10,
                sunrise: "05:48 AM",
                sunset: "06:52 PM",
                bgClass: "nagpur-bg",
                iconType: "sun",
                emoji: "🍊"
            },
            {
                city: "Bangalore",
                state: "Karnataka",
                temp: 26,
                feelsLike: 27,
                high: 30,
                low: 20,
                condition: "Partly Cloudy",
                description: "Pleasant weather with scattered clouds",
                humidity: 62,
                wind: 15,
                windDir: "E",
                visibility: 10,
                uvIndex: 6,
                pressure: 1013,
                dewPoint: 18,
                cloudCover: 45,
                sunrise: "06:05 AM",
                sunset: "06:38 PM",
                bgClass: "bangalore-bg",
                iconType: "cloud",
                emoji: "🌿"
            },
            {
                city: "Delhi",
                state: "NCR",
                temp: 35,
                feelsLike: 39,
                high: 40,
                low: 27,
                condition: "Hazy",
                description: "Warm and hazy with moderate smog",
                humidity: 45,
                wind: 8,
                windDir: "NW",
                visibility: 4,
                uvIndex: 7,
                pressure: 1006,
                dewPoint: 22,
                cloudCover: 25,
                sunrise: "05:32 AM",
                sunset: "07:05 PM",
                bgClass: "delhi-bg",
                iconType: "haze",
                emoji: "🏛️"
            }
        ];
        // Weather icons as SVG
        function getWeatherIcon(type) {
            if (type === "sun") {
                return `
                    <svg class="w-20 h-20 text-yellow-300 sun-icon" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z"/>
                    </svg>`;
            } else if (type === "cloud") {
                return `
                    <svg class="w-20 h-20 text-white cloud-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/>
                        <circle cx="17" cy="7" r="3" fill="rgba(250,204,21,0.8)" stroke="none"/>
                        <line x1="17" y1="2.5" x2="17" y2="3.5" stroke="rgba(250,204,21,0.6)" stroke-width="1.5" stroke-linecap="round"/>
                        <line x1="20.2" y1="3.8" x2="19.5" y2="4.5" stroke="rgba(250,204,21,0.6)" stroke-width="1.5" stroke-linecap="round"/>
                        <line x1="21.5" y1="7" x2="20.5" y2="7" stroke="rgba(250,204,21,0.6)" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>`;
            } else {
                return `
                    <svg class="w-20 h-20 text-amber-200 haze-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <circle cx="12" cy="8" r="3.5" fill="rgba(251,191,36,0.6)" stroke="none"/>
                        <line x1="4" y1="15" x2="20" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
                        <line x1="6" y1="17.5" x2="18" y2="17.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
                        <line x1="8" y1="20" x2="16" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
                    </svg>`;
            }
        }
        function getUVLabel(uv) {
            if (uv <= 2) return { text: "Low", color: "text-green-400" };
            if (uv <= 5) return { text: "Moderate", color: "text-yellow-400" };
            if (uv <= 7) return { text: "High", color: "text-orange-400" };
            if (uv <= 10) return { text: "Very High", color: "text-red-400" };
            return { text: "Extreme", color: "text-purple-400" };
        }
        function getAQIBar(visibility) {
            const percent = Math.min((visibility / 10) * 100, 100);
            let color = "bg-green-400";
            if (visibility <= 4) color = "bg-red-400";
            else if (visibility <= 6) color = "bg-yellow-400";
            return { percent, color };
        }
        function renderCards() {
            const container = document.getElementById('cardsContainer');
            container.innerHTML = weatherData.map((data, index) => {
                const uvInfo = getUVLabel(data.uvIndex);
                const visBar = getAQIBar(data.visibility);
                return `
                <div class="weather-card ${data.bgClass} rounded-2xl overflow-hidden shadow-2xl relative">
                    <!-- Sparkles -->
                    <div class="sparkle" style="top:15%;left:80%;animation-delay:0s"></div>
                    <div class="sparkle" style="top:30%;left:15%;animation-delay:1s"></div>
                    <div class="sparkle" style="top:60%;left:90%;animation-delay:2s"></div>
                    <!-- Top Section -->
                    <div class="p-6 pb-4">
                        <div class="flex justify-between items-start">
                            <div>
                                <h2 class="text-2xl font-bold text-white">${data.city}</h2>
                                <p class="text-white/70 text-sm">${data.state}, India</p>
                            </div>
                            <div class="text-right">
                                ${getWeatherIcon(data.iconType)}
                            </div>
                        </div>
                        <div class="mt-2">
                            <div class="flex items-end gap-2">
                                <span class="text-7xl font-bold text-white temp-display">${data.temp}°</span>
                                <span class="text-white/70 text-lg mb-3">C</span>
                            </div>
                            <p class="text-white/90 font-medium text-lg">${data.condition}</p>
                            <p class="text-white/60 text-sm mt-1">${data.description}</p>
                        </div>
                        <!-- High / Low / Feels Like -->
                        <div class="flex gap-4 mt-4">
                            <div class="bg-white/15 rounded-lg px-3 py-2 text-center flex-1">
                                <p class="text-white/60 text-xs">High</p>
                                <p class="text-white font-semibold">${data.high}°</p>
                            </div>
                            <div class="bg-white/15 rounded-lg px-3 py-2 text-center flex-1">
                                <p class="text-white/60 text-xs">Low</p>
                                <p class="text-white font-semibold">${data.low}°</p>
                            </div>
                            <div class="bg-white/15 rounded-lg px-3 py-2 text-center flex-1">
                                <p class="text-white/60 text-xs">Feels Like</p>
                                <p class="text-white font-semibold">${data.feelsLike}°</p>
                            </div>
                        </div>
                    </div>
                    <!-- Details Section -->
                    <div class="bg-black/20 p-5 mt-2">
                        <div class="grid grid-cols-2 gap-3">
                            <div class="detail-item flex items-center gap-3 rounded-lg p-2">
                                <span class="text-xl">💧</span>
                                <div>
                                    <p class="text-white/50 text-xs">Humidity</p>
                                    <p class="text-white font-medium">${data.humidity}%</p>
                                </div>
                            </div>
                            <div class="detail-item flex items-center gap-3 rounded-lg p-2">
                                <span class="text-xl">💨</span>
                                <div>
                                    <p class="text-white/50 text-xs">Wind</p>
                                    <p class="text-white font-medium">${data.wind} km/h ${data.windDir}</p>
                                </div>
                            </div>
                            <div class="detail-item flex items-center gap-3 rounded-lg p-2">
                                <span class="text-xl">🌡️</span>
                                <div>
                                    <p class="text-white/50 text-xs">Pressure</p>
                                    <p class="text-white font-medium">${data.pressure} hPa</p>
                                </div>
                            </div>
                            <div class="detail-item flex items-center gap-3 rounded-lg p-2">
                                <span class="text-xl">🌫️</span>
                                <div>
                                    <p class="text-white/50 text-xs">Dew Point</p>
                                    <p class="text-white font-medium">${data.dewPoint}°C</p>
                                </div>
                            </div>
                        </div>
                        <!-- UV Index -->
                        <div class="mt-3 bg-white/10 rounded-lg p-3">
                            <div class="flex justify-between items-center mb-1">
                                <span class="text-white/60 text-xs">☀️ UV Index</span>
                                <span class="${uvInfo.color} text-sm font-medium">${data.uvIndex} - ${uvInfo.text}</span>
                            </div>
                            <div class="w-full bg-white/10 rounded-full h-1.5">
                                <div class="h-1.5 rounded-full bg-gradient-to-r from-green-400 via-yellow-400 to-red-500" style="width: ${(data.uvIndex / 11) * 100}%"></div>
                            </div>
                        </div>
                        <!-- Visibility -->
                        <div class="mt-2 bg-white/10 rounded-lg p-3">
                            <div class="flex justify-between items-center mb-1">
                                <span class="text-white/60 text-xs">👁️ Visibility</span>
                                <span class="text-white text-sm font-medium">${data.visibility} km</span>
                            </div>
                            <div class="w-full bg-white/10 rounded-full h-1.5">
                                <div class="${visBar.color} h-1.5 rounded-full" style="width: ${visBar.percent}%"></div>
                            </div>
                        </div>
                        <!-- Sunrise / Sunset -->
                        <div class="flex gap-3 mt-3">
                            <div class="flex items-center gap-2 bg-white/10 rounded-lg px-3 py-2 flex-1">
                                <span>🌅</span>
                                <div>
                                    <p class="text-white/50 text-[10px]">Sunrise</p>
                                    <p class="text-white text-sm font-medium">${data.sunrise}</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 bg-white/10 rounded-lg px-3 py-2 flex-1">
                                <span>🌇</span>
                                <div>
                                    <p class="text-white/50 text-[10px]">Sunset</p>
                                    <p class="text-white text-sm font-medium">${data.sunset}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>`;
            }).join('');
        }
        function renderComparison() {
            const params = [
                { label: "Temperature", key: "temp", unit: "°C", icon: "🌡️" },
                { label: "Feels Like", key: "feelsLike", unit: "°C", icon: "🤒" },
                { label: "Humidity", key: "humidity", unit: "%", icon: "💧" },
                { label: "Wind Speed", key: "wind", unit: " km/h", icon: "💨" },
                { label: "Visibility", key: "visibility", unit: " km", icon: "👁️" },
                { label: "UV Index", key: "uvIndex", unit: "", icon: "☀️" },
                { label: "Pressure", key: "pressure", unit: " hPa", icon: "🌡️" },
                { label: "Cloud Cover", key: "cloudCover", unit: "%", icon: "☁️" },
            ];
            const tbody = document.getElementById('comparisonBody');
            tbody.innerHTML = params.map((param, i) => {
                const values = weatherData.map(d => d[param.key]);
                const maxVal = Math.max(...values);
                return `
                <tr class="${i % 2 === 0 ? 'bg-slate-800/30' : 'bg-slate-800/10'} hover:bg-slate-700/30 transition-colors">
                    <td class="px-6 py-3 text-slate-300 text-sm font-medium">${param.icon} ${param.label}</td>
                    ${weatherData.map((d, j) => {
                        const isMax = d[param.key] === maxVal;
                        return `<td class="px-6 py-3 text-center">
                            <span class="${isMax ? 'text-white font-bold' : 'text-slate-400'} text-sm">
                                ${d[param.key]}${param.unit}
                                ${isMax ? ' ⭐' : ''}
                            </span>
                        </td>`;
                    }).join('')}
                </tr>`;
            }).join('');
        }
        function renderFunFacts() {
            // Hottest
            const hottest = weatherData.reduce((a, b) => a.temp > b.temp ? a : b);
            document.getElementById('hottestCity').textContent =
                `${hottest.city} leads at ${hottest.temp}°C with ${hottest.condition.toLowerCase()} conditions.`;
            // Most humid
            const humid = weatherData.reduce((a, b) => a.humidity > b.humidity ? a : b);
            document.getElementById('humidCity').textContent =
                `${humid.city} has the highest humidity at ${humid.humidity}%.`;
            // Windiest
            const windy = weatherData.reduce((a, b) => a.wind > b.wind ? a : b);
            document.getElementById('windiestCity').textContent =
                `${windy.city} has winds blowing at ${windy.wind} km/h ${windy.windDir}.`;
        }
        function updateTime() {
            const now = new Date();
            const options = {
                weekday: 'short', year: 'numeric', month: 'short',
                day: 'numeric', hour: '2-digit', minute: '2-digit'
            };
            document.getElementById('lastUpdated').textContent =
                `Last updated: ${now.toLocaleDateString('en-IN', options)}`;
        }
        // Initialize
        renderCards();
        renderComparison();
        renderFunFacts();
        updateTime();
        setInterval(updateTime, 60000);
    </script>
</body>
</html>
