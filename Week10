<li>Deployment & Hosting</li>
</ul>

</section>

<!-- TESTIMONIALS -->
<section class="testimonials">
<h2 class="section-title">Student Testimonials</h2>

<div class="testimonial-grid">

<div class="testimonial">
<p>"This bootcamp helped me land my first developer job in just 3 months."</p>
<h4>Rahul Sharma</h4>
</div>

<div class="testimonial">
<p>"Best practical training and amazing mentors. Highly recommended."</p>
<h4>Priya Verma</h4>
</div>

<div class="testimonial">
<p>"I built real projects and gained confidence in coding."</p>
<h4>Amit Patel</h4>
</div>

</div>

</section>

<!-- PRICING -->
<section class="pricing" id="pricing">
<h2 class="section-title">Course Pricing</h2>

<div class="price-grid">

<div class="price-card">
<h3>Basic</h3>
<p class="price">₹4,999</p>
<p>Recorded Classes</p>
<p>Projects</p>
<br>
<button class="btn">Enroll</button>
</div>

<div class="price-card">
<h3>Pro</h3>
<p class="price">₹9,999</p>
<p>Live Classes</p>
<p>Projects</p>
<p>Placement Support</p>
<br>
<button class="btn">Enroll</button>
</div>

<div class="price-card">
<h3>Premium</h3>
<p class="price">₹14,999</p>
<p>Live Classes</p>
<p>1:1 Mentorship</p>
<p>Placement Guarantee</p>
<br>
<button class="btn">Enroll</button>
</div>

</div>

</section>

<!-- CONTACT -->
<section class="contact" id="contact">
<h2 class="section-title">Register Now</h2>

<form>
<input type="text" placeholder="Full Name" required>
<input type="email" placeholder="Email Address" required>
<input type="tel" placeholder="Phone Number" required>
<textarea rows="4" placeholder="Message"></textarea>

<button class="btn" type="submit">Submit</button>

</form>

</section>

<footer>
<p>© 2026 EliteCode Bootcamp | All Rights Reserved</p>
</footer>

</body>
</html>
