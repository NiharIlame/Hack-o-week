<p>Interactive sessions with doubt solving.</p>
</div>

</div>
</section>

<!-- CURRICULUM -->
<section class="curriculum" id="curriculum">
<h2 class="section-title">Course Curriculum</h2>

<ul>
<li>HTML, CSS & Responsive Design</li>
<li>JavaScript & DOM Projects</li>
