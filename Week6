<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Master - MCQ Quiz Platform</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .container {
            width: 100%;
            max-width: 900px;
        }
        /* Welcome Screen */
        .welcome-screen {
            background: white;
            border-radius: 20px;
            padding: 60px 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            text-align: center;
            animation: slideIn 0.5s ease-out;
        }
        .welcome-screen h1 {
            color: #667eea;
            font-size: 48px;
            margin-bottom: 10px;
            animation: fadeInDown 0.6s ease-out;
        }
        .welcome-screen p {
            color: #666;
            font-size: 18px;
            margin-bottom: 40px;
            animation: fadeInDown 0.7s ease-out;
        }
        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
            animation: fadeInUp 0.8s ease-out;
        }
        .feature-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px 20px;
            border-radius: 15px;
            transition: transform 0.3s ease;
        }
        .feature-card:hover {
            transform: translateY(-5px);
        }
        .feature-card .emoji {
            font-size: 40px;
            display: block;
            margin-bottom: 10px;
        }
        .feature-card h3 {
            margin-bottom: 10px;
            font-size: 18px;
        }
        .feature-card p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 14px;
            margin: 0;
        }
        .input-section {
            margin-bottom: 30px;
            animation: fadeInUp 0.9s ease-out;
        }
        .input-section label {
            display: block;
            color: #333;
            font-weight: 600;
            margin-bottom: 10px;
            font-size: 16px;
        }
        .input-section input {
            width: 100%;
            max-width: 400px;
            padding: 15px 20px;
            border: 2px solid #667eea;
            border-radius: 10px;
            font-size: 16px;
            transition: all 0.3s ease;
        }
        .input-section input:focus {
            outline: none;
            border-color: #764ba2;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }
        .btn {
            padding: 15px 40px;
            font-size: 16px;
            font-weight: 600;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            animation: fadeInUp 1s ease-out;
        }
        .btn-primary:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        }
        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        .btn-secondary {
            background: white;
            color: #667eea;
            border: 2px solid #667eea;
        }
        .btn-secondary:hover {
            background: #667eea;
            color: white;
        }
        /* Quiz Screen */
        .quiz-screen {
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            animation: slideIn 0.5s ease-out;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 20px;
        }
        .header h2 {
            color: #333;
            font-size: 24px;
        }
        .score-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px 30px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 18px;
        }
        .progress-container {
            margin-bottom: 30px;
        }
        .progress-text {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            color: #666;
            font-size: 14px;
        }
        .progress-bar {
            width: 100%;
            height: 8px;
            background: #e0e0e0;
            border-radius: 10px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
            transition: width 0.3s ease;
            border-radius: 10px;
        }
        .question-card {
            background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
            padding: 30px;
            border-radius: 15px;
            margin-bottom: 30px;
            animation: fadeIn 0.5s ease-out;
        }
        .question-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }
        .category-badge {
            background: #667eea;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }
        .difficulty-badge {
            font-size: 14px;
            font-weight: 600;
            padding: 5px 12px;
            border-radius: 20px;
        }
        .difficulty-easy {
            background: #d4edda;
            color: #155724;
        }
        .difficulty-medium {
            background: #fff3cd;
            color: #856404;
        }
        .difficulty-hard {
            background: #f8d7da;
            color: #721c24;
        }
        .question-text {
            font-size: 20px;
            font-weight: 600;
            color: #333;
            margin-bottom: 25px;
            line-height: 1.6;
        }
        .options {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .option {
            padding: 18px 20px;
            border: 2px solid #ddd;
            border-radius: 10px;
            cursor: pointer;
            background: white;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            font-size: 16px;
            font-weight: 500;
        }
        .option:hover:not(.disabled) {
            border-color: #667eea;
            background: rgba(102, 126, 234, 0.05);
            transform: translateX(5px);
        }
        .option.selected {
            border-color: #667eea;
            background: rgba(102, 126, 234, 0.1);
        }
        .option.correct {
            border-color: #28a745;
            background: #d4edda;
            color: #155724;
        }
        .option.incorrect {
            border-color: #dc3545;
            background: #f8d7da;
            color: #721c24;
        }
        .option.disabled {
            cursor: not-allowed;
        }
        .option-label {
            display: inline-block;
            width: 30px;
            height: 30px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-weight: 600;
            min-width: 30px;
        }
        .option.correct .option-label,
        .option.incorrect .option-label {
            background: transparent;
            margin-right: 15px;
        }
        .option.correct .option-label::before {
            content: '✓';
            font-size: 20px;
            color: #28a745;
        }
        .option.incorrect .option-label::before {
            content: '✗';
            font-size: 20px;
            color: #dc3545;
        }
        .explanation {
            background: #e7f3ff;
            border-left: 4px solid #667eea;
            padding: 15px 20px;
            border-radius: 5px;
            margin-top: 20px;
            color: #004085;
            font-size: 14px;
            line-height: 1.6;
            animation: slideDown 0.3s ease-out;
        }
        .btn-group {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }
        /* Results Screen */
        .results-screen {
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            text-align: center;
            animation: slideIn 0.5s ease-out;
        }
        .results-screen h1 {
            color: #333;
            font-size: 36px;
            margin-bottom: 20px;
        }
        .score-display {
            font-size: 64px;
            font-weight: 700;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 20px;
            animation: scaleIn 0.6s ease-out;
        }
        .percentage {
            font-size: 28px;
            color: #666;
            margin-bottom: 20px;
        }
        .performance-badge {
            display: inline-block;
            padding: 15px 30px;
            border-radius: 50px;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 30px;
            animation: popIn 0.6s ease-out;
        }
        .performance-outstanding {
            background: #ffd700;
            color: #333;
        }
        .performance-excellent {
            background: #32cd32;
            color: white;
        }
        .performance-good {
            background: #87ceeb;
            color: white;
        }
        .performance-review {
            background: #ff6b6b;
            color: white;
        }
        .message {
            font-size: 18px;
            color: #666;
            margin-bottom: 30px;
            line-height: 1.6;
        }
        .review-section {
            text-align: left;
            margin: 30px 0;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 15px;
            max-height: 400px;
            overflow-y: auto;
        }
        .review-section h3 {
            color: #333;
            margin-bottom: 20px;
            text-align: center;
        }
        .review-item {
            background: white;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
            border-left: 4px solid #dc3545;
        }
        .review-item.correct {
            border-left-color: #28a745;
        }
        .review-question {
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
        }
        .review-answer {
            color: #666;
            font-size: 14px;
            margin-bottom: 5px;
        }
        .review-answer.wrong {
            color: #dc3545;
        }
        .review-answer.correct {
            color: #28a745;
        }
        /* Leaderboard */
        .leaderboard-screen {
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            animation: slideIn 0.5s ease-out;
        }
        .leaderboard-screen h1 {
            text-align: center;
            color: #333;
            margin-bottom: 30px;
            font-size: 36px;
        }
        .leaderboard-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }
        .leaderboard-table th {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px;
            text-align: left;
            font-weight: 600;
        }
        .leaderboard-table td {
            padding: 15px;
            border-bottom: 1px solid #e0e0e0;
        }
        .leaderboard-table tr:hover {
            background: #f5f5f5;
        }
        .rank {
            font-size: 20px;
            font-weight: 700;
        }
        .rank.gold {
            color: #ffd700;
        }
        .rank.silver {
            color: #c0c0c0;
        }
        .rank.bronze {
            color: #cd7f32;
        }
        .empty-leaderboard {
            text-align: center;
            padding: 40px;
            color: #999;
            font-size: 18px;
        }
        /* Animations */
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @keyframes scaleIn {
            from {
                opacity: 0;
                transform: scale(0.5);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
        @keyframes popIn {
            0% {
                opacity: 0;
                transform: scale(0.8);
            }
            50% {
                transform: scale(1.1);
            }
            100% {
                opacity: 1;
                transform: scale(1);
            }
        }
        /* Responsive */
        @media (max-width: 768px) {
            .welcome-screen {
                padding: 40px 20px;
            }
            .welcome-screen h1 {
                font-size: 32px;
            }
            .quiz-screen {
                padding: 20px;
            }
            .question-card {
                padding: 20px;
            }
            .question-text {
                font-size: 18px;
            }
            .score-display {
                font-size: 48px;
            }
            .results-screen h1 {
                font-size: 28px;
            }
            .header {
                flex-direction: column;
            }
            .leaderboard-table {
                font-size: 14px;
            }
            .leaderboard-table th,
            .leaderboard-table td {
                padding: 10px;
            }
        }
        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Welcome Screen -->
        <div id="welcomeScreen" class="welcome-screen">
            <h1>🎯 Quiz Master</h1>
            <p>Test your knowledge with our amazing quiz platform</p>
            
            <div class="features">
                <div class="feature-card">
                    <span class="emoji">⚡</span>
                    <h3>Quick Questions</h3>
                    <p>5 engaging questions</p>
                </div>
                <div class="feature-card">
                    <span class="emoji">✨</span>
                    <h3>Instant Feedback</h3>
                    <p>Get answers instantly</p>
                </div>
                <div class="feature-card">
                    <span class="emoji">🏆</span>
                    <h3>Leaderboard</h3>
                    <p>Track your progress</p>
                </div>
            </div>
            <div class="input-section">
                <label for="studentName">Enter Your Name:</label>
                <input type="text" id="studentName" placeholder="Your full name" maxlength="50">
            </div>
            <button class="btn btn-primary" onclick="startQuiz()" id="startBtn">Start Quiz 🚀</button>
        </div>
        <!-- Quiz Screen -->
        <div id="quizScreen" class="quiz-screen hidden">
            <div class="header">
                <h2>📚 Quiz</h2>
                <div class="score-box">Score: <span id="currentScore">0</span>/5</div>
            </div>
            <div class="progress-container">
                <div class="progress-text">
                    <span>Question <span id="currentQuestion">1</span> of 5</span>
                    <span id="progressPercentage">0%</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill" style="width: 0%"></div>
                </div>
            </div>
            <div class="question-card">
                <div class="question-header">
                    <span class="category-badge" id="categoryBadge">Category</span>
                    <span class="difficulty-badge difficulty-easy" id="difficultyBadge">Easy</span>
                </div>
                <div class="question-text" id="questionText">Question goes here?</div>
                <div class="options" id="optionsContainer"></div>
                <div id="explanationBox" class="explanation hidden"></div>
            </div>
            <div class="btn-group">
                <button class="btn btn-primary" onclick="nextQuestion()" id="nextBtn" disabled>Next Question →</button>
                <button class="btn btn-secondary" onclick="goToLeaderboard()">View Leaderboard</button>
            </div>
        </div>
        <!-- Results Screen -->
        <div id="resultsScreen" class="results-screen hidden">
            <h1>🎉 Quiz Complete!</h1>
            <div class="score-display" id="finalScore">0/5</div>
            <div class="percentage" id="percentageDisplay">0%</div>
            <div class="performance-badge" id="performanceBadge">Good Job!</div>
            <div class="message" id="message">Great effort!</div>
            <div class="review-section" id="reviewSection"></div>
            <div class="btn-group">
                <button class="btn btn-primary" onclick="restartQuiz()">Retake Quiz 🔄</button>
                <button class="btn btn-secondary" onclick="goToLeaderboard()">View Leaderboard 🏆</button>
            </div>
        </div>
        <!-- Leaderboard Screen -->
        <div id="leaderboardScreen" class="leaderboard-screen hidden">
            <h1>🏆 Leaderboard</h1>
            <div id="leaderboardContent">
                <div class="empty-leaderboard">No records yet. Start the quiz!</div>
            </div>
            <div class="btn-group">
                <button class="btn btn-primary" onclick="goToWelcome()">← Back to Quiz</button>
            </div>
        </div>
    </div>
    <script>
        // Quiz Data
        const quizData = [
            {
                question: "What is the capital of France?",
                category: "Geography",
                difficulty: "easy",
                options: ["London", "Berlin", "Paris", "Madrid"],
                correct: 2,
                explanation: "Paris is the capital and largest city of France, located in the north-central part of the country."
            },
            {
                question: "Which planet is known as the Red Planet?",
                category: "Science",
                difficulty: "easy",
                options: ["Venus", "Mars", "Jupiter", "Saturn"],
                correct: 1,
                explanation: "Mars is called the Red Planet because of its reddish color caused by iron oxide on its surface."
            },
            {
                question: "What is the chemical symbol for Gold?",
                category: "Chemistry",
                difficulty: "medium",
                options: ["Go", "Gd", "Au", "Ag"],
                correct: 2,
                explanation: "Au is the chemical symbol for gold, derived from its Latin name 'Aurum'."
            },
            {
                question: "In which year did World War II end?",
                category: "History",
                difficulty: "medium",
                options: ["1943", "1944", "1945", "1946"],
                correct: 2,
                explanation: "World War II officially ended in 1945 with the surrender of Japan in September."
            },
            {
                question: "What is the smallest prime number?",
                category: "Mathematics",
                difficulty: "hard",
                options: ["0", "1", "2", "3"],
                correct: 2,
                explanation: "2 is the smallest prime number and the only even prime number."
            }
        ];
        // State Management
        let currentQuestion = 0;
        let score = 0;
        let studentName = '';
        let answers = [];
        let screen = 'welcome';
        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('studentName').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') startQuiz();
            });
        });
        // Start Quiz
        function startQuiz() {
            const name = document.getElementById('studentName').value.trim();
            if (name === '') {
                alert('Please enter your name to start the quiz!');
                return;
            }
            studentName = name;
            currentQuestion = 0;
            score = 0;
            answers = [];
            screen = 'quiz';
            showScreen('quizScreen');
            loadQuestion();
        }
        // Load Question
        function loadQuestion() {
            const question = quizData[currentQuestion];
            document.getElementById('categoryBadge').textContent = question.category;
            document.getElementById('difficultyBadge').textContent = question.difficulty.toUpperCase();
            document.getElementById('difficultyBadge').className = `difficulty-badge difficulty-${question.difficulty}`;
            document.getElementById('questionText').textContent = question.question;
            document.getElementById('currentQuestion').textContent = currentQuestion + 1;
            document.getElementById('currentScore').textContent = score;
            document.getElementById('progressFill').style.width = ((currentQuestion + 1) / 5 * 100) + '%';
            document.getElementById('progressPercentage').textContent = Math.round((currentQuestion + 1) / 5 * 100) + '%';
            // Clear previous options
            const optionsContainer = document.getElementById('optionsContainer');
            optionsContainer.innerHTML = '';
            document.getElementById('explanationBox').classList.add('hidden');
            document.getElementById('nextBtn').disabled = true;
            // Add options
            question.options.forEach((option, index) => {
                const div = document.createElement('div');
                div.className = 'option';
                div.innerHTML = `<span class="option-label">${String.fromCharCode(65 + index)}</span>${option}`;
                div.onclick = () => selectOption(index);
                div.id = `option-${index}`;
                optionsContainer.appendChild(div);
            });
        }
        // Select Option
        function selectOption(index) {
            const question = quizData[currentQuestion];
            const optionsContainer = document.getElementById('optionsContainer');
            const options = optionsContainer.querySelectorAll('.option');
            
            // Disable all options
            options.forEach(opt => opt.classList.add('disabled'));
            // Mark selected and correct/incorrect
            options.forEach((opt, i) => {
                if (i === question.correct) {
                    opt.classList.add('correct');
                } else if (i === index) {
                    opt.classList.add('incorrect');
                }
            });
            // Show explanation
            const explanationBox = document.getElementById('explanationBox');
            explanationBox.textContent = question.explanation;
            explanationBox.classList.remove('hidden');
            // Update score
            if (index === question.correct) {
                score++;
                document.getElementById('currentScore').textContent = score;
            }
            answers.push({
                question: question.question,
                selected: question.options[index],
                correct: question.options[question.correct],
                isCorrect: index === question.correct
            });
            // Enable next button
            document.getElementById('nextBtn').disabled = false;
        }
        // Next Question
        function nextQuestion() {
            currentQuestion++;
            if (currentQuestion < 5) {
                loadQuestion();
            } else {
                showResults();
            }
        }
        // Show Results
        function showResults() {
            screen = 'results';
            const percentage = (score / 5) * 100;
            document.getElementById('finalScore').textContent = `${score}/5`;
            document.getElementById('percentageDisplay').textContent = `${percentage.toFixed(1)}%`;
            let performanceLevel, badge, message;
            if (percentage === 100) {
                performanceLevel = 'outstanding';
                badge = '🥇 Outstanding!';
                message = `Congratulations ${studentName}! Perfect score! You're a quiz master! 🌟`;
            } else if (percentage >= 80) {
                performanceLevel = 'excellent';
                badge = '🥈 Excellent!';
                message = `Great job ${studentName}! You scored ${score}/5. Keep it up! 👏`;
            } else if (percentage >= 60) {
                performanceLevel = 'good';
                badge = '🥉 Good!';
                message = `Well done ${studentName}! You scored ${score}/5. Nice effort! 💪`;
            } else {
                performanceLevel = 'review';
                badge = '📚 Keep Learning!';
                message = `${studentName}, you scored ${score}/5. Review the material and try again! 📖`;
            }
            document.getElementById('performanceBadge').textContent = badge;
            document.getElementById('performanceBadge').className = `performance-badge performance-${performanceLevel}`;
            document.getElementById('message').textContent = message;
            // Show review
            const reviewSection = document.getElementById('reviewSection');
            const incorrectAnswers = answers.filter(a => !a.isCorrect);
            
            if (incorrectAnswers.length > 0) {
                reviewSection.innerHTML = '<h3>Review Incorrect Answers:</h3>';
                incorrectAnswers.forEach((answer, index) => {
                    const div = document.createElement('div');
                    div.className = 'review-item';
                    div.innerHTML = `
                        <div class="review-question">${index + 1}. ${answer.question}</div>
                        <div class="review-answer wrong">Your Answer: ${answer.selected}</div>
                        <div class="review-answer correct">Correct Answer: ${answer.correct}</div>
                    `;
                    reviewSection.appendChild(div);
                });
            } else {
                reviewSection.innerHTML = '<h3>✨ Perfect! All answers correct!</h3>';
            }
            // Save to leaderboard
            saveToLeaderboard(studentName, score, percentage);
            showScreen('resultsScreen');
        }
        // Leaderboard Functions
        function saveToLeaderboard(name, score, percentage) {
            let leaderboard = JSON.parse(localStorage.getItem('quizLeaderboard')) || [];
            leaderboard.push({
                name: name,
                score: score,
                percentage: percentage,
                date: new Date().toLocaleDateString()
            });
            leaderboard.sort((a, b) => b.percentage - a.percentage);
            localStorage.setItem('quizLeaderboard', JSON.stringify(leaderboard));
        }
        function goToLeaderboard() {
            screen = 'leaderboard';
            showScreen('leaderboardScreen');
            displayLeaderboard();
        }
        function displayLeaderboard() {
            const leaderboard = JSON.parse(localStorage.getItem('quizLeaderboard')) || [];
            const leaderboardContent = document.getElementById('leaderboardContent');
            if (leaderboard.length === 0) {
                leaderboardContent.innerHTML = '<div class="empty-leaderboard">No records yet. Start the quiz!</div>';
                return;
            }
            let html = '<table class="leaderboard-table"><thead><tr><th>Rank</th><th>Name</th><th>Score</th><th>Percentage</th><th>Date</th></tr></thead><tbody>';
            
            leaderboard.slice(0, 20).forEach((entry, index) => {
                let rankEmoji = '';
                let rankClass = '';
                if (index === 0) {
                    rankEmoji = '🥇';
                    rankClass = 'gold';
                } else if (index === 1) {
                    rankEmoji = '🥈';
                    rankClass = 'silver';
                } else if (index === 2) {
                    rankEmoji = '🥉';
                    rankClass = 'bronze';
                } else {
                    rankEmoji = '#' + (index + 1);
                }
                html += `<tr>
                    <td><span class="rank ${rankClass}">${rankEmoji}</span></td>
                    <td>${entry.name}</td>
                    <td>${entry.score}/5</td>
                    <td>${entry.percentage.toFixed(1)}%</td>
                    <td>${entry.date}</td>
                </tr>`;
            });
            html += '</tbody></table>';
            leaderboardContent.innerHTML = html;
        }
        // Navigation
        function restartQuiz() {
            goToWelcome();
        }
        function goToWelcome() {
            document.getElementById('studentName').value = '';
            document.getElementById('startBtn').disabled = false;
            showScreen('welcomeScreen');
            screen = 'welcome';
        }
        // Show Screen Helper
        function showScreen(screenId) {
            document.getElementById('welcomeScreen').classList.add('hidden');
            document.getElementById('quizScreen').classList.add('hidden');
            document.getElementById('resultsScreen').classList.add('hidden');
            document.getElementById('leaderboardScreen').classList.add('hidden');
            document.getElementById(screenId).classList.remove('hidden');
        }
    </script>
</body>
</html>
