<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Artisan's Coffee — Small Batch Roasters</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@300;400;500;600&family=Instrument+Serif:ital@0;1&family=Fraunces:opsz,wght@9..144,300;9..144,400&display=swap">
    <style>
        :root {
            --brown-950: #1a0f0b;
            --brown-900: #251a15;
            --brown-800: #3a2419;
            --brown-700: #5a3928;
            --brown-600: #7a4f37;
            --brown-500: #8b5a3c;
            --brown-400: #a0785a;
            --brown-300: #c19a7a;
            --brown-200: #dcc5a8;
            --brown-100: #f0e6d8;
            --cream: #fdf9f3;
        }
        body { font-family: "Crimson Pro", serif; }
        .font-serif-display { font-family: "Instrument Serif", serif; }
        .font-fraunces { font-family: "Fraunces", serif; }
        .coffee-steam::before,
        .coffee-steam::after {
            content: '';
            position: absolute;
            top: -18px;
            width: 2px;
            height: 26px;
            background: linear-gradient(to top, rgba(253,249,243,0.0), rgba(253,249,243,0.35));
            border-radius: 999px;
            filter: blur(0.5px);
            animation: steamRise 3.5s infinite ease-in-out;
        }
        .coffee-steam::before { left: 42%; animation-delay: 0s; transform: skewX(-8deg); }
        .coffee-steam::after { left: 58%; animation-delay: 1s; transform: skewX(8deg); }
        @keyframes steamRise {
            0% { transform: translateY(6px) scaleY(0.8); opacity: 0; }
            20% { opacity: 0.45; }
            100% { transform: translateY(-18px) scaleY(1.15); opacity: 0; }
        }
        .bean-float { animation: beanFloat 6s ease-in-out infinite; }
        @keyframes beanFloat {
            0%, 100% { transform: translateY(0) rotate(-2deg); }
            50% { transform: translateY(-8px) rotate(2deg); }
        }
        .grain-texture {
            background-image:
                radial-gradient(#000 1px, transparent 1px),
                radial-gradient(#000 1px, transparent 1px);
            background-size: 32px 32px;
            background-position: 0 0, 16px 16px;
            opacity: 0.025;
            mix-blend-mode: multiply;
        }
    </style>
</head>
<body class="min-h-dvh bg-[var(--cream)] text-[var(--brown-900)] antialiased selection:bg-[var(--brown-200)] selection:text-[var(--brown-900)]">
    <!-- Subtle paper grain -->
    <div class="pointer-events-none fixed inset-0 grain-texture"></div>

    <div class="relative mx-auto max-w-[1200px] px-5 sm:px-6 lg:px-8">
        <!-- Top bar -->
        <div class="flex items-center justify-between pt-6 pb-4 text-[13px] tracking-[0.18em] uppercase">
            <span class="opacity-60">Small Batch · Direct Trade · Roasted in Pune</span>
            <button id="cart-toggle" class="group relative inline-flex items-center gap-2 rounded-full border border-[var(--brown-300)]/60 bg-white/60 px-4 py-2 backdrop-blur-xl transition hover:border-[var(--brown-400)]">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="stroke-[var(--brown-700)]"><path d="M6 6h15l-1.5 9h-13.5l-2-13h-3" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span class="tabular-nums" id="cart-count">0</span>
                <span class="absolute -right-1 -top-1 h-2 w-2 rounded-full bg-[var(--brown-600)] opacity-0 transition group-[.has-items]:opacity-100"></span>
            </button>
        </div>

        <!-- Header -->
        <header class="relative border-b border-[var(--brown-200)] pb-8">
            <div class="flex flex-col items-start gap-6 md:flex-row md:items-end md:justify-between">
                <div>
                    <h1 class="font-serif-display text-[44px] leading-[0.92] tracking-[-0.02em] sm:text-[64px] lg:text-[78px]">
                        Artisan's<br><span class="italic">Coffee</span>
                    </h1>
                    <p class="mt-4 max-w-[44ch] text-[15.5px] leading-[1.65] text-[var(--brown-700)]">
                        We roast in 3–5kg batches, twice weekly, to reveal each origin's quiet complexity.
                        No lot numbers, no jargon—just honest coffee.
                    </p>
                </div>
                <div class="relative h-[78px] w-[78px] shrink-0">
                    <div class="absolute inset-0 rounded-full border border-[var(--brown-300)]/50 bg-[var(--brown-100)]"></div>
                    <div class="bean-float absolute left-1/2 top-1/2 h-[42px] w-[28px] -translate-x-1/2 -translate-y-1/2 rounded-[55%_45%_48%_52%/60%_58%_42%_40%] bg-[var(--brown-800)] shadow-[inset_0_0_0_2px_rgba(255,255,255,0.06)]"></div>
                    <div class="absolute left-[24%] top-[38%] h-1.5 w-4 rounded-full bg-[var(--brown-100)] opacity-60 blur-[0.3px]"></div>
                </div>
            </div>
        </header>

        <!-- Filters -->
        <section class="flex flex-wrap items-center gap-2 py-6 text-[13px]">
            <span class="mr-2 opacity-60 tracking-[0.2em] uppercase">Roast</span>
            <div id="roast-filters" class="flex flex-wrap gap-2">
                <button data-roast="all" class="filter-btn rounded-full border border-[var(--brown-300)]/70 bg-white px-4 py-[9px] transition data-[active=true]:bg-[var(--brown-900)] data-[active=true]:text-white">All</button>
                <button data-roast="light" class="filter-btn rounded-full border border-[var(--brown-300)]/70 bg-white px-4 py-[9px] transition">Light</button>
                <button data-roast="medium" class="filter-btn rounded-full border border-[var(--brown-300)]/70 bg-white px-4 py-[9px] transition">Medium</button>
                <button data-roast="dark" class="filter-btn rounded-full border border-[var(--brown-300)]/70 bg-white px-4 py-[9px] transition">Dark</button>
            </div>
            <div class="ml-auto flex items-baseline gap-3 text-right">
                <span class="text-[11px] tracking-[0.3em] uppercase opacity-50">Prices in</span>
                <span class="font-fraunces text-[22px] tracking-[-0.02em]">₹ INR</span>
            </div>
        </section>

        <!-- Product Grid -->
        <main class="grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-3">
            <!-- Product cards injected here -->
        </main>

        <!-- Footer note -->
        <footer class="border-t border-[var(--brown-200)] py-10 text-center text-[13px] leading-relaxed text-[var(--brown-700)]">
            <p>Roasted to order. Ships within 24 hours. Free shipping over ₹1,200.</p>
            <p class="mt-1 opacity-70">Artisan's Coffee, Koregaon Park, Pune · Since 2019</p>
        </footer>
    </div>

    <!-- Slide-in Cart -->
    <aside id="cart-drawer" class="pointer-events-none fixed inset-0 z-40">
        <div id="cart-backdrop" class="absolute inset-0 bg-[var(--brown-950)]/0 backdrop-blur-0 transition-all duration-300"></div>
        <div id="cart-panel" class="absolute right-0 top-0 h-full w-[min(92vw,420px)] translate-x-full bg-[var(--cream)] shadow-[-16px_0_60px_rgba(26,15,11,0.18)] ring-1 ring-[var(--brown-200)] transition-transform duration-500 will-change-transform">
            <div class="flex h-full flex-col">
                <div class="flex items-center justify-between border-b border-[var(--brown-200)] p-6">
                    <h3 class="font-serif-display text-[28px]">Your Sack</h3>
                    <button id="cart-close" class="rounded-full border border-[var(--brown-300)]/60 p-2.5 transition hover:bg-white">✕</button>
                </div>
                <div id="cart-items" class="flex-1 space-y-4 overflow-y-auto p-6 text-[15px]"></div>
                <div class="border-t border-[var(--brown-200)] bg-white/60 p-6 backdrop-blur-xl">
                    <div class="mb-4 flex items-baseline justify-between">
                        <span class="text-[13px] tracking-[0.25em] uppercase opacity-70">Total</span>
                        <span id="cart-total" class="font-fraunces text-[28px] tabular-nums">₹0</span>
                    </div>
                    <button id="checkout-btn" class="w-full rounded-full bg-[var(--brown-900)] py-[14px] text-[15px] tracking-[0.08em] text-white uppercase transition hover:bg-[var(--brown-800)] active:scale-[0.99]">Proceed to Roast</button>
                    <p class="mt-3 text-center text-[11.5px] opacity-65">Taxes calculated at next step. We roast after payment.</p>
                </div>
            </div>
        </div>
    </aside>

    <!-- Toast -->
    <div id="toast" class="pointer-events-none fixed bottom-6 left-1/2 z-50 w-[92vw] max-w-[420px] -translate-x-1/2 translate-y-8 rounded-2xl border border-[var(--brown-300)]/70 bg-white/90 px-5 py-4 text-[14.5px] shadow-[0_10px_40px_rgba(26,15,11,0.14)] backdrop-blur-2xl opacity-0 transition-all duration-300">
        <div class="flex items-center gap-3">
            <span class="flex h-7 w-7 items-center justify-center rounded-full bg-[var(--brown-900)] text-[11px] font-medium text-white">+</span>
            <span id="toast-text">Added to sack</span>
        </div>
    </div>

    <script>
        // Product data — 7 carefully curated coffees with Indian pricing (₹) and authentic imagery
        const products = [
            {
                id: "eth-yirga",
                name: "Ethiopia Yirgacheffe",
                origin: "Gedeo Zone, 1,950 masl",
                roast: "light",
                process: "Washed",
                notes: "Jasmine, bergamot, honeyed lemon",
                price: 890,
                weight: "250g",
                intensity: 3,
                story: "Floral and poised. Our lightest roast to preserve origin character.",
                image: "https://images.unsplash.com/photo-1511920170033-f8396924c348?w=800&auto=format&fit=crop&q=80", // Ethiopian highlands coffee farm with ripe red cherries
            },
            {
                id: "ken-nyeri",
                name: "Kenya Nyeri AA",
                origin: "Karogoto Factory, 1,700 masl",
                roast: "light",
                process: "Double-washed",
                notes: "Blackcurrant, tamarind, brown spice",
                price: 940,
                weight: "250g",
                intensity: 4,
                story: "Crisp acidity, winey depth — a Kenyan classic, bright as monsoon light.",
                image: "https://images.unsplash.com/photo-1447933601403-0c6688de566e?w=800&auto=format&fit=crop&q=80", // Close-up of fresh coffee cherries on branch in African sun
            },
            {
                id: "ind-bababudan",
                name: "India Bababudangiri",
                origin: "Chikmagalur, 1,250 masl",
                roast: "medium",
                process: "Natural",
                notes: "Milk chocolate, dried fig, toasted almond",
                price: 720,
                weight: "250g",
                intensity: 5,
                story: "Homegrown comfort. Ripe fruit sweetness wrapped in cocoa.",
                image: "https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=800&auto=format&fit=crop&q=80", // Indian coffee estate with misty Western Ghats hills
            },
            {
                id: "col-huila",
                name: "Colombia Huila",
                origin: "Acevedo, 1,650 masl",
                roast: "medium",
                process: "Washed",
                notes: "Panela, red apple, caramel",
                price: 790,
                weight: "250g",
                intensity: 6,
                story: "All-rounder brilliance — balance you can trust, cup after cup.",
                image: "https://images.unsplash.com/photo-1450024529640-858babe196fc?w=800&auto=format&fit=crop&q=80", // Colombian coffee drying patio with workers in colorful traditional clothing
            },
            {
                id: "pan-geisha-nat",
                name: "Panama Geisha Natural",
                origin: "Boquete, 1,600 masl",
                roast: "light",
                process: "Natural",
                notes: "Peach blossom, lychee, raw sugar",
                price: 1890,
                weight: "125g",
                intensity: 2,
                story: "Rare and radiant. Small lot, cupped at 89.5. For quiet mornings.",
                image: "https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=800&auto=format&fit=crop&q=75&sat=-20", // Misty high-altitude panama farm showing delicate geisha trees
            },
            {
                id: "sum-mandheling",
                name: "Sumatra Mandheling",
                origin: "West Sumatra, 1,400 masl",
                roast: "dark",
                process: "Wet-hulled",
                notes: "Dark chocolate, cedar, dried tobacco",
                price: 840,
                weight: "250g",
                intensity: 8,
                story: "Earthy, syrupy, contemplative. Espresso’s old friend.",
                image: "https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=800&auto=format&fit=crop&q=80", // Dark roasted Sumatran beans glistening with natural oils
            },
            {
                id: "bra-cerrado",
                name: "Brazil Cerrado",
                origin: "Minas Gerais, 1,100 masl",
                roast: "dark",
                process: "Pulped Natural",
                notes: "Hazelnut, cocoa nib, sweet pipe tobacco",
                price: 680,
                weight: "250g",
                intensity: 7,
                story: "Low-acid comfort with a long, nutty finish. Ideal for milk.",
                image: "https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=800&auto=format&fit=crop&q=85&blur=1", // Vast Brazilian cerrado plateau with mechanical harvesters at golden hour
            }
        ];

        // State
        let cart = JSON.parse(localStorage.getItem('artisans-cart') || '[]');
        let activeRoast = 'all';

        // Elements
        const grid = document.querySelector('main');
        const cartToggle = document.getElementById('cart-toggle');
        const cartDrawer = document.getElementById('cart-drawer');
        const cartPanel = document.getElementById('cart-panel');
        const cartBackdrop = document.getElementById('cart-backdrop');
        const cartClose = document.getElementById('cart-close');
        const cartItemsEl = document.getElementById('cart-items');
        const cartTotalEl = document.getElementById('cart-total');
        const cartCountEl = document.getElementById('cart-count');
        const toast = document.getElementById('toast');
        const toastText = document.getElementById('toast-text');
        const filterBtns = document.querySelectorAll('.filter-btn');

        // Utility: INR formatting
        const fmtINR = (n) => '₹' + n.toLocaleString('en-IN');

        // Render products with staggered animation
        function renderProducts() {
            grid.innerHTML = '';
            const filtered = activeRoast === 'all' ? products : products.filter(p => p.roast === activeRoast);
            
            filtered.forEach((p, i) => {
                const card = document.createElement('article');
                card.className = 'group relative overflow-hidden rounded-[28px] border border-[var(--brown-200)] bg-white/70 backdrop-blur-2xl transition-all duration-500 hover:border-[var(--brown-300)] hover:shadow-[0_18px_60px_rgba(90,57,40,0.12)]';
                card.style.animationDelay = `${i * 60}ms`;
                card.innerHTML = `
                    <div class="relative h-[210px] overflow-hidden bg-[var(--brown-100)]">
                        <div class="absolute inset-0 bg-gradient-to-tr from-[var(--brown-900)]/25 to-transparent mix-blend-multiply z-10"></div>
                        <!-- Coffee product image matching the name -->
                        <img src="${p.image}" alt="${p.name} coffee beans from ${p.origin}" class="absolute inset-0 h-full w-full object-cover transition-all duration-700 group-hover:scale-[1.03]" loading="lazy" onerror="this.style.opacity='0.2'"/>
                        <!-- Steam animation container -->
                        <div class="coffee-steam absolute left-1/2 top-[54%] h-0 w-0 -translate-x-1/2"></div>
                        <span class="absolute left-4 top-4 rounded-full bg-white/85 px-3 py-1.5 text-[11px] tracking-[0.24em] uppercase backdrop-blur-xl">${p.roast}</span>
                        <span class="absolute right-4 top-4 rounded-full border border-[var(--brown-300)]/60 bg-[var(--cream)]/80 px-3 py-1.5 text-[11px] font-medium tracking-[0.18em] uppercase backdrop-blur-xl">${p.weight}</span>
                    </div>
                    <div class="relative p-[22px]">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <h3 class="font-fraunces text-[22px] leading-[1.12] tracking-[-0.015em]">${p.name}</h3>
                                <p class="mt-1 text-[13px] leading-snug text-[var(--brown-700)]">${p.origin} · ${p.process}</p>
                            </div>
                            <div class="shrink-0 text-right">
                                <div class="font-fraunces text-[24px] tracking-[-0.02em]">${fmtINR(p.price)}</div>
                                <div class="mt-0.5 text-[11px] tracking-[0.32em] uppercase opacity-60">per ${p.weight}</div>
                            </div>
                        </div>
                        <p class="mt-4 line-clamp-2 text-[14.5px] leading-[1.55] text-[var(--brown-800)]">"${p.notes}"</p>
                        <!-- Intensity bar -->
                        <div class="mt-5 flex items-center gap-3 text-[11px]">
                            <span class="tracking-[0.28em] uppercase opacity-60">Intensity</span>
                            <div class="relative h-[6px] flex-1 overflow-hidden rounded-full bg-[var(--brown-200)]">
                                <div class="absolute inset-y-0 left-0 w-[${p.intensity * 12.5}%] rounded-full bg-[var(--brown-700)] transition-all duration-700"></div>
                            </div>
                            <span class="tabular-nums">${p.intensity}/8</span>
                        </div>
                        <!-- Add button -->
                        <button data-id="${p.id}" class="add-btn mt-6 flex w-full items-center justify-center gap-2.5 rounded-full bg-[var(--brown-900)] py-[13px] text-[14px] tracking-[0.09em] text-white uppercase transition will-change-transform hover:bg-[var(--brown-800)] active:scale-[0.985]">
                            <span>Add to Sack</span>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </button>
                        <p class="mt-3 text-center text-[11.5px] italic tracking-[0.02em] text-[var(--brown-600)]">${p.story}</p>
                    </div>
                `;
                // Staggered entrance
                card.classList.add('opacity-0', 'translate-y-2');
                grid.appendChild(card);
                requestAnimationFrame(() => {
                    card.classList.remove('opacity-0', 'translate-y-2');
                    card.classList.add('transition-all', 'duration-700', 'ease-out');
                });
            });
        }

        // Cart logic
        function saveCart() {
            localStorage.setItem('artisans-cart', JSON.stringify(cart));
            const count = cart.reduce((s, i) => s + i.qty, 0);
            cartCountEl.textContent = count;
            cartToggle.classList.toggle('has-items', count > 0);
        }

        function addToCart(id) {
            const item = cart.find(i => i.id === id);
            if (item) item.qty += 1;
            else cart.push({ id, qty: 1 });
            saveCart();
            renderCart();
            showToast(`Added ${products.find(p => p.id === id).name}`);
            openCart();
        }

        function renderCart() {
            if (cart.length === 0) {
                cartItemsEl.innerHTML = `<div class="py-16 text-center text-[15px] italic text-[var(--brown-600)]">Your sack is empty. <br>Pick a roast, any roast.</div>`;
                cartTotalEl.textContent = fmtINR(0);
                return;
            }
            cartItemsEl.innerHTML = cart.map(ci => {
                const p = products.find(x => x.id === ci.id);
                return `
                <div class="flex gap-4 rounded-2xl border border-[var(--brown-200)] bg-white/70 p-4 backdrop-blur-xl">
                    <div class="relative h-[64px] w-[64px] shrink-0 overflow-hidden rounded-xl bg-[var(--brown-100)]">
                        <img src="${p.image}" alt="${p.name}" class="h-full w-full object-cover opacity-90" loading="lazy"/>
                    </div>
                    <div class="min-w-0 flex-1">
                        <div class="truncate font-medium">${p.name}</div>
                        <div class="text-[12.5px] text-[var(--brown-700)]">${p.weight} · ${p.roast}</div>
                        <div class="mt-2 text-[13.5px] font-medium">${fmtINR(p.price)} <span class="opacity-60">× ${ci.qty}</span></div>
                    </div>
                    <div class="flex flex-col items-end justify-between">
                        <button data-id="${p.id}" class="remove-one rounded-full border border-[var(--brown-300)]/60 p-1.5 text-[11px] hover:bg-[var(--brown-50)]">−</button>
                        <button data-id="${p.id}" class="remove-all text-[11px] tracking-[0.25em] uppercase text-[var(--brown-700)] underline decoration-[var(--brown-300)] underline-offset-4">Remove</button>
                    </div>
                </div>`;
            }).join('');
            const total = cart.reduce((sum, ci) => {
                const p = products.find(x => x.id === ci.id);
                return sum + (p.price * ci.qty);
            }, 0);
            cartTotalEl.textContent = fmtINR(total);
        }

        // Toast
        let toastTimer;
        function showToast(msg) {
            toastText.textContent = msg;
            toast.classList.remove('opacity-0', 'translate-y-8');
            toast.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-8');
                toast.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
            }, 1600);
        }

        // Cart drawer
        function openCart() {
            cartDrawer.classList.remove('pointer-events-none');
            cartPanel.classList.remove('translate-x-full');
            cartBackdrop.classList.add('bg-[var(--brown-950)]/35', 'backdrop-blur-[2px]');
        }
        function closeCart() {
            cartPanel.classList.add('translate-x-full');
            cartBackdrop.classList.remove('bg-[var(--brown-950)]/35', 'backdrop-blur-[2px]');
            setTimeout(() => cartDrawer.classList.add('pointer-events-none'), 300);
        }

        // Event listeners
        grid.addEventListener('click', (e) => {
            const btn = e.target.closest('.add-btn');
            if (!btn) return;
            const id = btn.dataset.id;
            // Micro-interaction: button press
            btn.classList.add('scale-[0.985]');
            setTimeout(() => btn.classList.remove('scale-[0.985]'), 90);
            addToCart(id);
        });

        cartItemsEl.addEventListener('click', (e) => {
            const one = e.target.closest('.remove-one');
            const all = e.target.closest('.remove-all');
            if (one) {
                const id = one.dataset.id;
                const item = cart.find(i => i.id === id);
                if (item) {
                    item.qty -= 1;
                    if (item.qty <= 0) cart = cart.filter(i => i.id !== id);
                    saveCart(); renderCart();
                }
            }
            if (all) {
                const id = all.dataset.id;
                cart = cart.filter(i => i.id !== id);
                saveCart(); renderCart(); showToast('Removed from sack');
            }
        });

        cartToggle.addEventListener('click', openCart);
        cartClose.addEventListener('click', closeCart);
        cartBackdrop.addEventListener('click', closeCart);

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.dataset.active = 'false');
                btn.dataset.active = 'true';
                activeRoast = btn.dataset.roast;
                renderProducts();
            });
        });

        document.getElementById('checkout-btn').addEventListener('click', () => {
            if (cart.length === 0) return showToast('Your sack is empty');
            showToast('Roasting your order now…');
            cart = []; saveCart(); renderCart(); closeCart();
        });

        // Init
        renderProducts();
        renderCart();
        saveCart(); // Init badge
        // Activate "All" filter
        document.querySelector('[data-roast="all"]').dataset.active = 'true';
    </script>
</body>
</html>
